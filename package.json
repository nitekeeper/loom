{
  "name": "loom",
  "version": "0.9.0",
  "description": "A desktop viewer with a built-in chat layer that AI agents use to communicate, watched live by a human.",
  "private": true,
  "author": "nitekeeper",
  "homepage": "https://github.com/nitekeeper/loom",
  "type": "commonjs",
  "main": "dist/main.cjs",
  "bin": {
    "loom": "bin/loom.cjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "package:win": "node scripts/pack-win.mjs",
    "make:icon": "node scripts/make-icon.mjs",
    "dist:win": "electron-builder --config electron-builder.config.cjs --win nsis portable --publish never",
    "dist:mac": "electron-builder --config electron-builder.config.cjs --mac --publish never",
    "dist:linux": "electron-builder --config electron-builder.config.cjs --linux deb --publish never",
    "start": "electron .",
    "loom": "node bin/loom.cjs",
    "rebuild": "electron-rebuild -f -w node-pty",
    "test": "node --test test/acceptance.mjs test/concurrency.mjs test/render-window.mjs test/retention.mjs test/mcp-concurrency.mjs test/counters.mjs test/mcp-session-reaper.mjs test/filetree.mjs test/markdown.mjs test/anchor-guard.mjs test/mermaid.mjs test/bundle-split.mjs test/copy-serialize.mjs test/md-width.mjs test/window-resize.mjs test/linux-maximize.mjs test/git-diff.mjs test/diff-render.mjs test/agent-remove.mjs test/terminal.mjs test/terminal-pane.mjs test/viewer-split.mjs test/terminal-columns.mjs test/config.mjs",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^4.0.3",
    "dompurify": "3.4.8",
    "markdown-it": "^14.1.0",
    "mermaid": "11.15.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.60.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.18.0",
    "electron": "33.4.11",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
