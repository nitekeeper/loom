# Dependencies
node_modules/

# Build output (esbuild -> dist/)
dist/

# Windows portable build output (scripts/pack-win.mjs)
release/

# Cached Electron win32 prebuilt (scripts/pack-win.mjs download cache)
.cache/loom-pack/

# Per-session SQLite store + runtime state (NFR-7, OQ-2)
.loom/
**/.loom/

# Logs, OS + editor cruft
*.log
.DS_Store
Thumbs.db
.idea/
.vscode/

# Capture/smoke artifacts
*.png.tmp
/tmp/loom_*.png

# Playwright e2e (Tier 2) output: HTML report + per-run results (CI uploads
# the report as an artifact; it must never be committed).
playwright-report/
test-results/
.last-run.json

# Windows (WSL) alternate-data-stream cruft
*:Zone.Identifier

# Code-signing certificate material — MUST NEVER be committed.
# Certs are supplied to CI as base64 GitHub Actions secrets (see docs/SIGNING.md),
# never as files in the repo.
*.p12
*.pfx
*.cer
*.key
*.keychain
*.mobileprovision

# Claude Code harness runtime state
.claude/

# Atelier scaffolding (mode marker / active-project pointer)
.ai/

# Atelier host-dispatch per-writer git worktrees (transient)
.atelier-worktrees/
